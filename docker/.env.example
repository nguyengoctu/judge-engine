# Problem DB
PROBLEM_DB_HOST=problem-db
PROBLEM_DB_PORT=5432
PROBLEM_DB_NAME=problemdb
PROBLEM_DB_USER=
PROBLEM_DB_PASSWORD=

# Submission DB
SUBMISSION_DB_HOST=submission-db
SUBMISSION_DB_PORT=5432
SUBMISSION_DB_NAME=submissiondb
SUBMISSION_DB_USER=
SUBMISSION_DB_PASSWORD=

# ───── Infrastructure ─────
REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=
RABBITMQ_PASS=

# ───── Services ─────
PROBLEM_SERVICE_HOST=problem-service
PROBLEM_SERVICE_PORT=8081
SUBMISSION_SERVICE_HOST=submission-service
SUBMISSION_SERVICE_PORT=8082

# ───── Executor ─────
EXECUTOR_MODE=docker
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_TIMEOUT=10
SANDBOX_PIDS_LIMIT=50
MOCK_EXEC_TIMEOUT=5
MOCK_EXEC_MAX_MEMORY=256

LOG_LEVEL=INFO
LOG_FORMAT=json

NGINX_PORT=80

SPRING_PROFILES_ACTIVE=dev