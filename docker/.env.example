# Database
DB_HOST=judge-db
DB_PORT=5432
DB_NAME=judgedb
POSTGRES_USER=
POSTGRES_PASSWORD=

# ───── Infrastructure ─────
REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=
RABBITMQ_PASS=

# ───── Services ─────
PROBLEM_SERVICE_HOST=problem-service
PROBLEM_SERVICE_PORT=8081
SUBMISSION_SERVICE_HOST=submission-service
SUBMISSION_SERVICE_PORT=8082

# ───── Executor ─────
EXECUTOR_MODE=docker
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_TIMEOUT=10
SANDBOX_PIDS_LIMIT=50
MOCK_EXEC_TIMEOUT=5
MOCK_EXEC_MAX_MEMORY=256

LOG_LEVEL=INFO
LOG_FORMAT=json

NGINX_PORT=80

SPRING_PROFILES_ACTIVE=dev